#include "stm32f1xx.h"
#include "FreeRTOS.h"
#include "task.h"

// Garante que a variável do CMSIS reflita os 8MHz reais
extern uint32_t SystemCoreClock; 

// Protótipos das funções de hardware
void RCC_Config(void);
void GPIO_Config(void);
void USART1_Config(void);
void ADC1_Config(void);
uint16_t ADC1_Read(void);
void USART1_SendChar(char c);
void USART1_SendInt(uint16_t val);

// Protótipo da Tarefa do FreeRTOS
void vTaskADCReadAndSend(void *pvParameters);

int main(void) {
    // Força o valor correto para que o FreeRTOS calcule os Ticks baseados em 8MHz
    SystemCoreClock = 8000000;

    // Inicializa os periféricos
    RCC_Config();
    GPIO_Config();
    USART1_Config();
    ADC1_Config();

    // Cria a tarefa responsável por ler o ADC e enviar pela Serial
    // Nome: "ADC_Task", Stack: 128 words, Prioridade: 1
    xTaskCreate(vTaskADCReadAndSend, "ADC_Task", 128, NULL, 1, NULL);

    // Inicia o escalonador do FreeRTOS
    vTaskStartScheduler();

    // O programa nunca deve chegar a este ponto
    while (1) {
    }
}

// --- Tarefa do FreeRTOS ---
void vTaskADCReadAndSend(void *pvParameters) {
    // Frequência de amostragem alterada para 2 milissegundos (500Hz)
    // Isso sincroniza perfeitamente com a leitura rápida do Python
    const TickType_t xFrequenciaAmostragem = pdMS_TO_TICKS(2);
    TickType_t xLastWakeTime = xTaskGetTickCount();

    while (1) {
        // Realiza a leitura analógica do BPW21R no PB1
        uint16_t leitura_fotodiodo = ADC1_Read();

        // Envia o valor e a quebra de linha ('\n' é essencial para o Python separar os dados)
        USART1_SendInt(leitura_fotodiodo);
        USART1_SendChar('\n');

        // Aguarda até ao próximo ciclo de 2ms cravados
        vTaskDelayUntil(&xLastWakeTime, xFrequenciaAmostragem);
    }
}

// --- Funções de Configuração de Hardware ---

void RCC_Config(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB2ENR |= RCC_APB2ENR_USART1EN | RCC_APB2ENR_ADC1EN; 
    
    // Prescaler do ADC (DIV6 para 8MHz é extremamente seguro)
    RCC->CFGR &= ~RCC_CFGR_ADCPRE;
    RCC->CFGR |= RCC_CFGR_ADCPRE_DIV6;
}

void GPIO_Config(void) {
    // USART1 TX (PA9) e RX (PA10)
    GPIOA->CRH &= ~(GPIO_CRH_CNF9 | GPIO_CRH_MODE9);
    GPIOA->CRH |= (GPIO_CRH_CNF9_1 | GPIO_CRH_MODE9_0);
    GPIOA->CRH &= ~(GPIO_CRH_CNF10 | GPIO_CRH_MODE10);
    GPIOA->CRH |= GPIO_CRH_CNF10_0;

    // ADC1_IN9 (PB1) - Modo Analógico
    GPIOB->CRL &= ~(GPIO_CRL_CNF1 | GPIO_CRL_MODE1);
}

void USART1_Config(void) {
    // Baud Rate: 115200 bps @ 8MHz
    USART1->BRR = 0x45; 
    USART1->CR1 |= (USART_CR1_TE | USART_CR1_RE | USART_CR1_UE);
}

void ADC1_Config(void) {
    ADC1->CR2 |= ADC_CR2_ADON;
    
    // Pequeno atraso para o ADC ligar
    for (volatile int i = 0; i < 10000; i++);
    
    // --- SOLUÇÃO DA CURVA NA BASE ---
    // Configura o tempo de amostragem do Canal 9 (PB1) para 239.5 ciclos.
    // O valor 7 (111 em binário) deslocado 27 posições altera os bits correspondentes.
    // Isso dá tempo suficiente para o capacitor interno do ADC ler a tensão com o resistor de 100k.
    ADC1->SMPR2 |= (7 << 27);
    
    // Calibração
    ADC1->CR2 |= ADC_CR2_CAL;
    while (ADC1->CR2 & ADC_CR2_CAL);
    
    // Configura sequência
    ADC1->SQR1 &= ~ADC_SQR1_L; 
    ADC1->SQR3 = 9; // Canal 9 (PB1)
}

uint16_t ADC1_Read(void) {
    ADC1->CR2 |= ADC_CR2_ADON;
    while (!(ADC1->SR & ADC_SR_EOC));
    return (uint16_t)(ADC1->DR & 0xFFF);
}

void USART1_SendChar(char c) {
    while (!(USART1->SR & USART_SR_TXE));
    USART1->DR = c;
}

void USART1_SendInt(uint16_t val) {
    char buffer[5]; 
    int i = 0;
    
    if (val == 0) {
        USART1_SendChar('0');
        return;
    }
    
    while (val > 0) {
        buffer[i++] = (val % 10) + '0';
        val /= 10;
    }
    
    while (i > 0) {
        USART1_SendChar(buffer[--i]);
    }
}
